#!/bin/sh
# LeakOS Live Initramfs Init Script
# Fixed v5 - Complete rewrite with better error handling

export PATH=/usr/bin:/usr/sbin:/bin:/sbin
export HOME=/

OVERRIDE_INIT=""
DEBUG_MODE=0

# ============================================
# Fungsi utilitas
# ============================================

log() {
    echo "[INIT] $*" > /dev/kmsg 2>/dev/null
    echo "[INIT] $*"
}

warn() {
    echo "[WARN] $*" > /dev/kmsg 2>/dev/null
    echo "[WARN] $*"
}

error() {
    echo "[ERROR] $*" > /dev/kmsg 2>/dev/null
    echo "[ERROR] $*"
}

emergency_shell() {
    echo ""
    echo "========================================"
    echo "  EMERGENCY SHELL - LeakOS Debug"
    echo "========================================"
    echo "Tips debug:"
    echo "  lsblk"
    echo "  blkid"
    echo "  mount"
    echo "  dmesg | tail -50"
    echo "  ls -la /bootmnt/boot/"
    echo "  cat /proc/modules"
    echo "  ls -la /dev/loop*"
    echo "========================================"
    echo ""
    
    # Start shell with proper environment
    export PS1='sh-debug# '
    exec /bin/sh
}

# ============================================
# Mount basic filesystems
# ============================================

mount_base() {
    log "Mounting base filesystems..."

    # Mount /proc first
    mount -t proc proc /proc 2>/dev/null || error "proc failed"
    
    # Mount /sys
    mount -t sysfs sysfs /sys 2>/dev/null || error "sysfs failed"
    
    # Mount /dev
    mount -t devtmpfs devtmpfs /dev 2>/dev/null || {
        mount -t tmpfs tmpfs /dev 2>/dev/null || error "devtmpfs failed"
    }
    
    # Mount /run
    mount -t tmpfs tmpfs /run 2>/dev/null || warn "tmpfs /run failed"
    
    # Mount /tmp
    mount -t tmpfs tmpfs /tmp 2>/dev/null || warn "tmpfs /tmp failed"

    # Create /dev/pts
    mkdir -p /dev/pts 2>/dev/null
    mount -t devpts devpts /dev/pts -o gid=5,mode=620 2>/dev/null || warn "devpts failed"

    # Create essential device nodes
    [ -c /dev/null ]    || mknod -m 666 /dev/null    c 1 3 2>/dev/null
    [ -c /dev/console ] || mknod -m 600 /dev/console c 5 1 2>/dev/null
    [ -c /dev/tty ]     || mknod -m 666 /dev/tty     c 5 0 2>/dev/null
    [ -c /dev/zero ]    || mknod -m 666 /dev/zero    c 1 5 2>/dev/null
    [ -c /dev/urandom ] || mknod -m 666 /dev/urandom c 1 9 2>/dev/null
    [ -c /dev/random ]  || mknod -m 666 /dev/random  c 1 8 2>/dev/null

    log "Base filesystems ready"
}

# ============================================
# Load kernel modules
# ============================================

load_modules() {
    log "Loading kernel modules..."

    # First, ensure /proc is mounted
    [ -d /proc ] || mkdir -p /proc
    
    # Load essential modules
    MODULES="squashfs overlay loop"
    
    for mod in $MODULES; do
        if modprobe "$mod" 2>/dev/null; then
            log "  Loaded: $mod"
        else
            warn "  Failed to load $mod"
            # Try with full path
            if [ -f "/lib/modules/$(uname -r)/kernel/fs/$mod/$mod.ko" ]; then
                insmod "/lib/modules/$(uname -r)/kernel/fs/$mod/$mod.ko" 2>/dev/null && log "  Loaded $mod via insmod"
            fi
        fi
    done

    # Load filesystem modules
    for mod in vfat exfat iso9660 ext4 ext3 ext2; do
        modprobe "$mod" 2>/dev/null
    done

    # Load storage drivers
    for mod in usb_storage sr_mod ahci nvme virtio_blk; do
        modprobe "$mod" 2>/dev/null
    done

    log "Modules loaded"
}

# ============================================
# Setup loop devices
# ============================================

setup_loop_devices() {
    log "Setting up loop devices..."
    
    # Create loop control if not exists
    [ -c /dev/loop-control ] || mknod -m 660 /dev/loop-control c 10 237 2>/dev/null
    
    # Create loop devices
    for i in 0 1 2 3 4 5 6 7; do
        if [ ! -b "/dev/loop$i" ]; then
            mknod -m 660 "/dev/loop$i" b 7 "$i" 2>/dev/null
        fi
    done
    
    log "Loop devices ready"
}

# ============================================
# Start udev (optional, can be skipped)
# ============================================

start_udev() {
    log "Starting udev (optional)..."
    
    # Skip udev if not available or in debug mode
    if [ "$DEBUG_MODE" -eq 1 ]; then
        warn "Debug mode: skipping udev"
        return 0
    fi

    # Find udevd
    UDEVD=""
    for p in /sbin/udevd /usr/sbin/udevd /lib/systemd/systemd-udevd /usr/lib/systemd/systemd-udevd; do
        if [ -x "$p" ]; then
            UDEVD="$p"
            break
        fi
    done

    if [ -z "$UDEVD" ]; then
        warn "udevd not found, continuing without udev"
        return 0
    fi

    # Start udevd
    $UDEVD --daemon 2>/dev/null
    
    # Trigger events
    if command -v udevadm >/dev/null 2>&1; then
        udevadm trigger --action=add 2>/dev/null
        udevadm settle --timeout=10 2>/dev/null
    fi

    log "udev started"
}

# ============================================
# Parse kernel command line
# ============================================

parse_cmdline() {
    [ -r /proc/cmdline ] || return

    for param in $(cat /proc/cmdline); do
        case "$param" in
            debug)
                DEBUG_MODE=1
                log "Debug mode enabled"
                set -x
                ;;
            rootdelay=*)
                delay="${param#rootdelay=}"
                log "Root delay: ${delay}s"
                sleep "$delay"
                ;;
            init=*)
                OVERRIDE_INIT="${param#init=}"
                log "Init override: $OVERRIDE_INIT"
                ;;
            single|s|1)
                log "Single user mode"
                OVERRIDE_INIT="/bin/sh"
                ;;
        esac
    done
}

# ============================================
# Mount boot media
# ============================================

mount_boot_media() {
    local BOOT_MNT="/bootmnt"
    
    log "Mounting boot media..."
    mkdir -p "$BOOT_MNT"
    
    # List all block devices
    log "Available block devices:"
    ls -la /dev/sd* /dev/hd* /dev/nvme* /dev/sr* 2>/dev/null || echo "  No devices found"
    
    # Try each device
    for device in /dev/sr0 /dev/sr1 /dev/cdrom /dev/dvd /dev/sda1 /dev/sda2 /dev/sdb1 /dev/sdb2 /dev/hda1 /dev/hda2; do
        [ -b "$device" ] || continue
        
        log "Trying device: $device"
        
        # Try iso9660 first (for optical media)
        if mount -t iso9660 -o ro "$device" "$BOOT_MNT" 2>/dev/null; then
            if [ -f "$BOOT_MNT/boot/lfs.squashfs" ] || [ -f "$BOOT_MNT/lfs.squashfs" ]; then
                log "Found boot media on $device (iso9660)"
                echo "$device"
                return 0
            fi
            umount "$BOOT_MNT" 2>/dev/null
        fi
        
        # Try vfat
        if mount -t vfat -o ro "$device" "$BOOT_MNT" 2>/dev/null; then
            if [ -f "$BOOT_MNT/boot/lfs.squashfs" ] || [ -f "$BOOT_MNT/lfs.squashfs" ]; then
                log "Found boot media on $device (vfat)"
                echo "$device"
                return 0
            fi
            umount "$BOOT_MNT" 2>/dev/null
        fi
        
        # Try ext4
        if mount -t ext4 -o ro "$device" "$BOOT_MNT" 2>/dev/null; then
            if [ -f "$BOOT_MNT/boot/lfs.squashfs" ] || [ -f "$BOOT_MNT/lfs.squashfs" ]; then
                log "Found boot media on $device (ext4)"
                echo "$device"
                return 0
            fi
            umount "$BOOT_MNT" 2>/dev/null
        fi
    done
    
    # Try scanning all partitions
    log "Scanning all partitions..."
    for part in $(ls /dev/sd* /dev/hd* /dev/nvme* 2>/dev/null); do
        [ -b "$part" ] || continue
        
        # Try to mount
        for fstype in iso9660 vfat exfat ext4 ext3 ext2 btrfs auto; do
            if mount -t "$fstype" -o ro "$part" "$BOOT_MNT" 2>/dev/null; then
                # Check for squashfs in various locations
                if [ -f "$BOOT_MNT/boot/lfs.squashfs" ]; then
                    log "Found lfs.squashfs at $part:/boot/lfs.squashfs"
                    echo "$part"
                    return 0
                elif [ -f "$BOOT_MNT/lfs.squashfs" ]; then
                    log "Found lfs.squashfs at $part:/lfs.squashfs"
                    echo "$part"
                    return 0
                elif [ -f "$BOOT_MNT/boot/rootfs.squashfs" ]; then
                    log "Found rootfs.squashfs at $part:/boot/rootfs.squashfs"
                    echo "$part"
                    return 0
                fi
                umount "$BOOT_MNT" 2>/dev/null
            fi
        done
    done
    
    error "No boot media with squashfs found"
    return 1
}

# ============================================
# Mount root filesystem
# ============================================

mount_root() {
    local BOOT_MNT="/bootmnt"
    local SQUASH_MNT="/squashfs"
    local ROOT_MNT="/newroot"
    local COW_DIR="/cow"
    
    log "========================================="
    log "Mounting root filesystem"
    log "========================================="
    
    # Create directories
    mkdir -p "$BOOT_MNT" "$SQUASH_MNT" "$ROOT_MNT" "$COW_DIR"
    
    # Find and mount boot media
    BOOT_DEV=$(mount_boot_media)
    if [ -z "$BOOT_DEV" ]; then
        error "Failed to find boot media"
        return 1
    fi
    
    log "Boot device mounted at $BOOT_MNT"
    
    # List boot media contents
    log "Boot media contents:"
    ls -la "$BOOT_MNT/" 2>/dev/null | head -10
    ls -la "$BOOT_MNT/boot/" 2>/dev/null | head -10
    
    # Find squashfs file
    SQUASHFS_FILE=""
    if [ -f "$BOOT_MNT/boot/lfs.squashfs" ]; then
        SQUASHFS_FILE="$BOOT_MNT/boot/lfs.squashfs"
    elif [ -f "$BOOT_MNT/lfs.squashfs" ]; then
        SQUASHFS_FILE="$BOOT_MNT/lfs.squashfs"
    elif [ -f "$BOOT_MNT/rootfs.squashfs" ]; then
        SQUASHFS_FILE="$BOOT_MNT/rootfs.squashfs"
    elif [ -f "$BOOT_MNT/boot/rootfs.squashfs" ]; then
        SQUASHFS_FILE="$BOOT_MNT/boot/rootfs.squashfs"
    else
        error "No squashfs file found"
        log "Searching for any .squashfs file:"
        find "$BOOT_MNT" -name "*.squashfs" 2>/dev/null
        return 1
    fi
    
    log "Found squashfs: $SQUASHFS_FILE"
    ls -lh "$SQUASHFS_FILE"
    
    # Mount squashfs
    log "Mounting squashfs..."
    if ! mount -t squashfs -o ro,loop "$SQUASHFS_FILE" "$SQUASH_MNT" 2>&1; then
        error "Failed to mount squashfs"
        log "Trying with explicit loop device..."
        
        # Try to find a free loop device
        for i in 0 1 2 3 4 5 6 7; do
            if losetup /dev/loop$i "$SQUASHFS_FILE" 2>/dev/null; then
                log "Set up /dev/loop$i for squashfs"
                if mount -t squashfs -o ro "/dev/loop$i" "$SQUASH_MNT" 2>/dev/null; then
                    log "Squashfs mounted via /dev/loop$i"
                    break
                fi
            fi
        done
        
        # Check if mounted
        if ! mountpoint -q "$SQUASH_MNT"; then
            error "Cannot mount squashfs"
            return 1
        fi
    fi
    
    log "Squashfs mounted at $SQUASH_MNT"
    
    # Verify squashfs content
    if [ -z "$(ls -A $SQUASH_MNT 2>/dev/null)" ]; then
        error "Squashfs is empty"
        return 1
    fi
    
    log "Squashfs root contents: $(ls $SQUASH_MNT | head -5)"
    
    # Setup writable overlay
    log "Setting up overlay..."
    if ! mount -t tmpfs -o mode=755 tmpfs "$COW_DIR"; then
        error "Failed to mount tmpfs for overlay"
        return 1
    fi
    
    mkdir -p "$COW_DIR/upper" "$COW_DIR/work"
    
    # Mount overlay
    log "Mounting overlay at $ROOT_MNT"
    if ! mount -t overlay overlay \
        -o lowerdir="$SQUASH_MNT",upperdir="$COW_DIR/upper",workdir="$COW_DIR/work" \
        "$ROOT_MNT"; then
        error "Failed to mount overlay"
        return 1
    fi
    
    log "Overlay mounted at $ROOT_MNT"
    
    # Verify overlay
    if ! mountpoint -q "$ROOT_MNT"; then
        error "Overlay mount verification failed"
        return 1
    fi
    
    # Create necessary directories in new root
    mkdir -p "$ROOT_MNT"/{dev,proc,sys,run,tmp,etc,root,home,var,usr,bin,sbin,lib,lib64,mnt,media,opt,srv}
    
    # Move mounts to new root
    log "Moving filesystems to new root..."
    
    # Move /dev
    mount --move /dev "$ROOT_MNT/dev" 2>/dev/null || {
        warn "Cannot move /dev, mounting new"
        mount -t devtmpfs devtmpfs "$ROOT_MNT/dev" 2>/dev/null
        # Copy existing device nodes
        cp -a /dev/* "$ROOT_MNT/dev/" 2>/dev/null
    }
    
    # Move /proc
    mount --move /proc "$ROOT_MNT/proc" 2>/dev/null || {
        warn "Cannot move /proc, mounting new"
        mount -t proc proc "$ROOT_MNT/proc" 2>/dev/null
    }
    
    # Move /sys
    mount --move /sys "$ROOT_MNT/sys" 2>/dev/null || {
        warn "Cannot move /sys, mounting new"
        mount -t sysfs sysfs "$ROOT_MNT/sys" 2>/dev/null
    }
    
    # Move /run
    mount --move /run "$ROOT_MNT/run" 2>/dev/null || {
        warn "Cannot move /run, mounting new"
        mount -t tmpfs tmpfs "$ROOT_MNT/run" 2>/dev/null
    }
    
    # Additional mounts
    mkdir -p "$ROOT_MNT/dev/pts"
    mount -t devpts devpts "$ROOT_MNT/dev/pts" -o gid=5,mode=620 2>/dev/null
    
    mount -t tmpfs tmpfs "$ROOT_MNT/tmp" 2>/dev/null
    
    # Bind mount boot media
    mkdir -p "$ROOT_MNT/mnt/bootmedia"
    mount --bind "$BOOT_MNT" "$ROOT_MNT/mnt/bootmedia" 2>/dev/null
    
    # Create essential device nodes in new root
    [ -c "$ROOT_MNT/dev/null" ] || mknod -m 666 "$ROOT_MNT/dev/null" c 1 3 2>/dev/null
    [ -c "$ROOT_MNT/dev/zero" ] || mknod -m 666 "$ROOT_MNT/dev/zero" c 1 5 2>/dev/null
    [ -c "$ROOT_MNT/dev/console" ] || mknod -m 600 "$ROOT_MNT/dev/console" c 5 1 2>/dev/null
    
    log "Root filesystem ready at $ROOT_MNT"
    
    # Show mount status
    log "Mounts in new root:"
    mount | grep "$ROOT_MNT" | head -5
    
    echo "$ROOT_MNT"
    return 0
}

# ============================================
# Find init in new root
# ============================================

find_init() {
    local ROOT_MNT="$1"
    
    log "Searching for init in $ROOT_MNT..."
    
    # Check override init
    if [ -n "$OVERRIDE_INIT" ]; then
        if [ -x "$ROOT_MNT$OVERRIDE_INIT" ]; then
            log "Using override init: $OVERRIDE_INIT"
            echo "$OVERRIDE_INIT"
            return 0
        fi
    fi
    
    # Standard init locations
    for init in /sbin/init /usr/sbin/init /bin/init /usr/bin/init /init; do
        if [ -x "$ROOT_MNT$init" ]; then
            log "Found init: $init"
            echo "$init"
            return 0
        fi
    done
    
    # Fallback to shell
    if [ -x "$ROOT_MNT/bin/sh" ]; then
        warn "No init found, using /bin/sh"
        echo "/bin/sh"
        return 0
    fi
    
    error "No init or shell found"
    return 1
}

# ============================================
# Main
# ============================================

log "========================================="
log "LeakOS Live Initramfs Starting"
log "========================================="
log "Kernel: $(uname -r)"

# Initialize
mount_base
parse_cmdline
load_modules
setup_loop_devices
start_udev

# Wait for devices
sleep 3

# Mount root filesystem
ROOT_MNT=$(mount_root)
if [ -z "$ROOT_MNT" ]; then
    error "Failed to mount root filesystem"
    emergency_shell
fi

# Find init
ROOT_INIT=$(find_init "$ROOT_MNT")
if [ -z "$ROOT_INIT" ]; then
    error "No init found"
    emergency_shell
fi

# Cleanup
log "Cleaning up..."
killall udevd 2>/dev/null
sleep 1

# Switch to new root
log "Switching to new root with init: $ROOT_INIT"
exec switch_root "$ROOT_MNT" "$ROOT_INIT"

# If we get here, something went wrong
error "switch_root failed"
emergency_shell
