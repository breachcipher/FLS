#!/bin/sh
# LeakOS Live Initramfs Init Script
# Fixed v4 - bind mount, no double mount, robust init search

export PATH=/usr/bin:/usr/sbin:/bin:/sbin
export HOME=/

OVERRIDE_INIT=""

# ============================================
# Fungsi utilitas
# ============================================

log() {
    echo "[INIT] $*" > /dev/kmsg 2>/dev/null
    echo "[INIT] $*"
}

warn() {
    echo "[WARN] $*" > /dev/kmsg 2>/dev/null
    echo "[WARN] $*"
}

error() {
    echo "[ERROR] $*" > /dev/kmsg 2>/dev/null
    echo "[ERROR] $*"
}

emergency_shell() {
    echo ""
    echo "========================================"
    echo "  EMERGENCY SHELL - LeakOS Debug"
    echo "========================================"
    echo "Tips debug:"
    echo "  mount | grep newroot"
    echo "  ls /newroot/sbin/ /newroot/bin/"
    echo "  file /newroot/sbin/init"
    echo "  ls /newroot/lib/ld-* /newroot/lib64/ld-*"
    echo "  exec switch_root /newroot /sbin/init"
    echo "========================================"
    exec /bin/sh
}

# ============================================
# Mount basic filesystems
# ============================================

mount_base() {
    log "Mounting base filesystems..."

    mount -t devtmpfs devtmpfs /dev 2>/dev/null || \
        mount -t tmpfs tmpfs /dev 2>/dev/null   || \
        error "devtmpfs failed"

    mount -t proc proc /proc       2>/dev/null || error "proc failed"
    mount -t sysfs sysfs /sys      2>/dev/null || error "sysfs failed"
    mount -t tmpfs tmpfs /run      2>/dev/null || warn "tmpfs /run failed"
    mount -t tmpfs tmpfs /tmp      2>/dev/null || warn "tmpfs /tmp failed"

    mkdir -p /dev/pts 2>/dev/null
    mount -t devpts devpts /dev/pts -o gid=5,mode=620 2>/dev/null || warn "devpts failed"

    [ -c /dev/null ]    || mknod -m 666 /dev/null    c 1 3
    [ -c /dev/console ] || mknod -m 600 /dev/console c 5 1
    [ -c /dev/tty ]     || mknod -m 666 /dev/tty     c 5 0
    [ -c /dev/tty1 ]    || mknod -m 600 /dev/tty1    c 4 1
    [ -c /dev/tty2 ]    || mknod -m 600 /dev/tty2    c 4 2
    [ -c /dev/urandom ] || mknod -m 666 /dev/urandom c 1 9
    [ -c /dev/random ]  || mknod -m 666 /dev/random  c 1 8

    log "Base filesystems ready"
}

# ============================================
# Load kernel modules
# ============================================

load_modules() {
    log "Loading kernel modules..."

    for mod in squashfs overlay loop; do
        modprobe -q "$mod" 2>/dev/null && log "  Loaded: $mod" || warn "  Failed: $mod"
    done

    for mod in vfat exfat iso9660 ext4 ext3 ext2 xfs btrfs; do
        modprobe -q "$mod" 2>/dev/null
    done

    for mod in usb_storage sr_mod ahci nvme virtio_blk mmc_block; do
        modprobe -q "$mod" 2>/dev/null
    done

    for mod in xhci_hcd ehci_hcd uhci_hcd; do
        modprobe -q "$mod" 2>/dev/null
    done

    log "Modules loaded"
}

# ============================================
# Setup loop devices
# ============================================

setup_loop_devices() {
    log "Setting up loop devices..."
    for i in 0 1 2 3 4 5 6 7; do
        [ -b "/dev/loop$i" ] || mknod -m 660 "/dev/loop$i" b 7 "$i" 2>/dev/null
    done
}

# ============================================
# Start udev
# ============================================

start_udev() {
    log "Starting udev..."

    UDEVD=""
    for p in /usr/lib/systemd/systemd-udevd /usr/lib/udev/udevd /sbin/udevd /usr/sbin/udevd; do
        [ -x "$p" ] && UDEVD="$p" && break
    done

    if [ -z "$UDEVD" ]; then
        warn "udevd not found, skipping"
        return
    fi

    $UDEVD --daemon --resolve-names=never 2>/dev/null
    udevadm trigger --action=add 2>/dev/null
    udevadm settle --timeout=30 2>/dev/null

    log "udev ready"
}

# ============================================
# Parse kernel command line
# ============================================

parse_cmdline() {
    [ -r /proc/cmdline ] || return

    for param in $(cat /proc/cmdline); do
        case "$param" in
            debug)
                log "Debug mode enabled"
                set -x
                ;;
            rootdelay=*)
                delay="${param#rootdelay=}"
                log "Root delay: ${delay}s"
                sleep "$delay"
                ;;
            init=*)
                OVERRIDE_INIT="${param#init=}"
                log "Init override: $OVERRIDE_INIT"
                ;;
        esac
    done
}

# ============================================
# Cari boot media dengan lfs.squashfs
# ============================================

find_boot_media() {
    local BOOT_MNT="/bootmnt"
    local timeout=60
    local elapsed=0

    log "Searching for boot media (timeout: ${timeout}s)..."
    mkdir -p "$BOOT_MNT" 2>/dev/null

    while [ $elapsed -lt $timeout ]; do
        for dev in $(ls /sys/block/ 2>/dev/null); do
            case "$dev" in
                loop*|ram*|dm-*) continue ;;
            esac

            for part in /dev/${dev}p[0-9]* /dev/${dev}[0-9]*; do
                [ -b "$part" ] || continue
                for fstype in iso9660 vfat exfat ext4 ext3 ext2; do
                    if mount -t "$fstype" -o ro "$part" "$BOOT_MNT" 2>/dev/null; then
                        if [ -f "$BOOT_MNT/boot/lfs.squashfs" ]; then
                            log "Found: $part (partition)"
                            echo "$part"
                            return 0
                        fi
                        umount "$BOOT_MNT" 2>/dev/null
                    fi
                done
            done

            if [ -b "/dev/$dev" ]; then
                for fstype in iso9660 udf; do
                    if mount -t "$fstype" -o ro "/dev/$dev" "$BOOT_MNT" 2>/dev/null; then
                        if [ -f "$BOOT_MNT/boot/lfs.squashfs" ]; then
                            log "Found: /dev/$dev (whole disk)"
                            echo "/dev/$dev"
                            return 0
                        fi
                        umount "$BOOT_MNT" 2>/dev/null
                    fi
                done
            fi
        done

        sleep 2
        elapsed=$((elapsed + 2))
        [ $((elapsed % 10)) -eq 0 ] && log "Still searching... (${elapsed}s)"
    done

    return 1
}

# ============================================
# Mount root filesystem (squashfs + overlay)
# ============================================

mount_root() {
    local BOOT_MNT="/bootmnt"
    local SQUASH_MNT="/squashfs"
    local ROOT_MNT="/newroot"
    local COW_DIR="/cow"
    local UPPER_DIR="$COW_DIR/upper"
    local WORK_DIR="$COW_DIR/work"

    log "Mounting root filesystem..."
    mkdir -p "$BOOT_MNT" "$SQUASH_MNT" "$ROOT_MNT" "$COW_DIR"

    # Cari boot media
    BOOT_DEV=$(find_boot_media)
    if [ -z "$BOOT_DEV" ]; then
        error "Boot media tidak ditemukan!"
        lsblk 2>/dev/null || cat /proc/partitions
        return 1
    fi

    log "Boot device: $BOOT_DEV"

    # find_boot_media sudah mount ke BOOT_MNT — jangan double mount
    if mountpoint -q "$BOOT_MNT" 2>/dev/null; then
        log "Boot media sudah termount di $BOOT_MNT, skip"
    else
        if ! mount -t auto -o ro "$BOOT_DEV" "$BOOT_MNT"; then
            error "Gagal mount $BOOT_DEV"
            return 1
        fi
    fi

    # Verifikasi squashfs
    if [ ! -f "$BOOT_MNT/boot/lfs.squashfs" ]; then
        error "lfs.squashfs tidak ada di $BOOT_MNT/boot/"
        ls -la "$BOOT_MNT/boot/" 2>/dev/null
        return 1
    fi

    log "lfs.squashfs ditemukan"

    # Mount squashfs
    if ! mount -t squashfs -o loop "$BOOT_MNT/boot/lfs.squashfs" "$SQUASH_MNT"; then
        error "Gagal mount squashfs"
        return 1
    fi

    log "Squashfs mounted di $SQUASH_MNT"

    # Verifikasi squashfs tidak kosong
    if [ -z "$(ls -A "$SQUASH_MNT" 2>/dev/null)" ]; then
        error "Squashfs kosong!"
        return 1
    fi

    # Mount tmpfs untuk overlay
    if ! mount -t tmpfs -o mode=755 tmpfs "$COW_DIR"; then
        error "Gagal mount tmpfs untuk overlay"
        return 1
    fi

    mkdir -p "$UPPER_DIR" "$WORK_DIR"

    # Mount overlay
    if ! mount -t overlay overlay \
        -o lowerdir="$SQUASH_MNT",upperdir="$UPPER_DIR",workdir="$WORK_DIR" \
        "$ROOT_MNT"; then
        error "Gagal mount overlay"
        return 1
    fi

    log "Overlay mounted di $ROOT_MNT"

    # Bind mount boot media ke dalam rootfs
    mkdir -p "$ROOT_MNT/mnt/bootmedia" 2>/dev/null
    mount --bind "$BOOT_MNT" "$ROOT_MNT/mnt/bootmedia" 2>/dev/null || \
        warn "Gagal bind mount boot media"

    # Bind mount pseudo-filesystems ke newroot
    # Gunakan --bind bukan --move karena rootfs shared mount
    for fs in dev proc sys run; do
        if [ -d "/$fs" ] && [ -d "$ROOT_MNT/$fs" ]; then
            if mount --bind "/$fs" "$ROOT_MNT/$fs" 2>/dev/null; then
                log "Bind mounted /$fs ke $ROOT_MNT/$fs"
            else
                warn "Gagal bind /$fs, coba mount langsung..."
                case "$fs" in
                    dev)
                        mount -t devtmpfs devtmpfs "$ROOT_MNT/dev" 2>/dev/null || \
                            warn "devtmpfs di newroot gagal"
                        ;;
                    proc)
                        mount -t proc proc "$ROOT_MNT/proc" 2>/dev/null || \
                            warn "proc di newroot gagal"
                        ;;
                    sys)
                        mount -t sysfs sysfs "$ROOT_MNT/sys" 2>/dev/null || \
                            warn "sysfs di newroot gagal"
                        ;;
                    run)
                        mount -t tmpfs tmpfs "$ROOT_MNT/run" 2>/dev/null || \
                            warn "tmpfs run di newroot gagal"
                        ;;
                esac
            fi
        fi
    done

    # devpts di newroot
    mkdir -p "$ROOT_MNT/dev/pts" 2>/dev/null
    mount -t devpts devpts "$ROOT_MNT/dev/pts" -o gid=5,mode=620 2>/dev/null || \
        warn "devpts di newroot gagal"

    # Pastikan /dev/null ada
    [ -c "$ROOT_MNT/dev/null" ] || \
        mknod -m 666 "$ROOT_MNT/dev/null" c 1 3 2>/dev/null

    # Pastikan /dev/console ada
    [ -c "$ROOT_MNT/dev/console" ] || \
        mknod -m 600 "$ROOT_MNT/dev/console" c 5 1 2>/dev/null

    log "Root filesystem siap di $ROOT_MNT"
    echo "$ROOT_MNT"
    return 0
}

# ============================================
# Dump debug info rootfs
# ============================================

dump_rootfs_info() {
    local ROOT_MNT="$1"

    log "=== DEBUG ROOTFS ==="
    log "Isi $ROOT_MNT:"
    ls "$ROOT_MNT/" 2>/dev/null

    log "Isi $ROOT_MNT/sbin/:"
    ls -la "$ROOT_MNT/sbin/" 2>/dev/null | head -20

    log "Isi $ROOT_MNT/bin/:"
    ls "$ROOT_MNT/bin/" 2>/dev/null | head -10

    log "Dynamic linker:"
    ls "$ROOT_MNT/lib/"ld-*     2>/dev/null
    ls "$ROOT_MNT/lib64/"ld-*   2>/dev/null
    ls "$ROOT_MNT/usr/lib/"ld-* 2>/dev/null

    log "file /sbin/init:"
    file "$ROOT_MNT/sbin/init" 2>/dev/null || \
        log "(file command tidak tersedia di initramfs)"

    log "Mount table:"
    mount | grep -E "newroot|squash|overlay|cow"

    log "=== END DEBUG ==="
}

# ============================================
# Cari dan verifikasi init
# ============================================

find_root_init() {
    local ROOT_MNT="$1"

    # Override dari cmdline
    if [ -n "$OVERRIDE_INIT" ]; then
        if [ -x "$ROOT_MNT$OVERRIDE_INIT" ]; then
            log "Using cmdline init: $OVERRIDE_INIT"
            echo "$OVERRIDE_INIT"
            return 0
        else
            error "Override init tidak ada: $ROOT_MNT$OVERRIDE_INIT"
        fi
    fi

    # Cek kandidat
    for init in \
        /sbin/init \
        /usr/sbin/init \
        /bin/init \
        /usr/bin/init \
        /usr/lib/systemd/systemd \
        /lib/systemd/systemd \
        /sbin/openrc-init \
        /init
    do
        if [ -x "$ROOT_MNT$init" ]; then
            log "Found init: $init"
            echo "$init"
            return 0
        fi
    done

    # Fallback /bin/sh
    if [ -x "$ROOT_MNT/bin/sh" ]; then
        warn "Fallback ke /bin/sh"
        echo "/bin/sh"
        return 0
    fi

    return 1
}

# ============================================
# Cleanup sebelum switch_root
# ============================================

cleanup() {
    log "Cleaning up..."
    killall udevd 2>/dev/null
    killall systemd-udevd 2>/dev/null
    # Jangan umount /dev/pts di initramfs karena sudah dibind ke newroot
}

# ============================================
# MAIN
# ============================================

log "=== LeakOS Live Initramfs Starting ==="
log "Kernel: $(uname -r)"

mount_base
parse_cmdline
load_modules
setup_loop_devices
start_udev

ROOT_MNT=$(mount_root)
if [ -z "$ROOT_MNT" ]; then
    error "Gagal mount root filesystem!"
    emergency_shell
fi

dump_rootfs_info "$ROOT_MNT"

ROOT_INIT=$(find_root_init "$ROOT_MNT")
if [ -z "$ROOT_INIT" ]; then
    error "Init tidak ditemukan di $ROOT_MNT!"
    emergency_shell
fi

cleanup

log "Switching to $ROOT_MNT with init $ROOT_INIT"

exec switch_root "$ROOT_MNT" "$ROOT_INIT"

error "switch_root GAGAL!"
emergency_shell
