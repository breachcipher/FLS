#!/bin/sh
# LeakOS Live Initramfs Init Script
# Fixed v6 - Full ELF verification and better switch_root

export PATH=/usr/bin:/usr/sbin:/bin:/sbin
export HOME=/

OVERRIDE_INIT=""
DEBUG_MODE=0

# ============================================
# Utility functions
# ============================================

log() {
    echo "[INIT] $*" > /dev/kmsg 2>/dev/null
    echo "[INIT] $*"
}

warn() {
    echo "[WARN] $*" > /dev/kmsg 2>/dev/null
    echo "[WARN] $*"
}

error() {
    echo "[ERROR] $*" > /dev/kmsg 2>/dev/null
    echo "[ERROR] $*"
}

emergency_shell() {
    echo ""
    echo "========================================"
    echo "  EMERGENCY SHELL - LeakOS Debug"
    echo "========================================"
    echo "Check root filesystem:"
    echo "  ls -la /newroot/"
    echo "  ls -la /newroot/sbin/"
    echo "  ls -la /newroot/bin/"
    echo "  ls -la /newroot/lib/"
    echo "  ls -la /newroot/lib64/"
    echo ""
    echo "Check init:"
    echo "  file /newroot/sbin/init"
    echo "  ldd /newroot/sbin/init"
    echo "  readelf -l /newroot/sbin/init | grep interpreter"
    echo ""
    echo "Mount status:"
    echo "  mount | grep newroot"
    echo "  cat /proc/mounts | grep newroot"
    echo ""
    echo "Try manual switch_root:"
    echo "  exec switch_root /newroot /sbin/init"
    echo "========================================"
    exec /bin/sh
}

# ============================================
# Mount base filesystems
# ============================================

mount_base() {
    log "Mounting base filesystems..."

    mount -t devtmpfs devtmpfs /dev 2>/dev/null || \
        mount -t tmpfs tmpfs /dev 2>/dev/null

    mount -t proc proc /proc 2>/dev/null
    mount -t sysfs sysfs /sys 2>/dev/null
    mount -t tmpfs tmpfs /run 2>/dev/null
    mount -t tmpfs tmpfs /tmp 2>/dev/null

    mkdir -p /dev/pts
    mount -t devpts devpts /dev/pts -o gid=5,mode=620 2>/dev/null

    # Create essential device nodes
    [ -c /dev/null ]    || mknod -m 666 /dev/null c 1 3
    [ -c /dev/console ] || mknod -m 600 /dev/console c 5 1
    [ -c /dev/tty ]     || mknod -m 666 /dev/tty c 5 0
    [ -c /dev/zero ]    || mknod -m 666 /dev/zero c 1 5
    [ -c /dev/random ]  || mknod -m 666 /dev/random c 1 8
    [ -c /dev/urandom ] || mknod -m 666 /dev/urandom c 1 9

    log "Base filesystems ready"
}

# ============================================
# Load kernel modules
# ============================================

load_modules() {
    log "Loading kernel modules..."

    # Essential modules
    for mod in loop squashfs overlay; do
        modprobe "$mod" 2>/dev/null && log "  Loaded: $mod" || warn "  Failed: $mod"
    done

    # Filesystem modules
    for mod in iso9660 vfat ext4; do
        modprobe "$mod" 2>/dev/null
    done

    # Storage drivers
    for mod in sr_mod ahci usb_storage; do
        modprobe "$mod" 2>/dev/null
    done

    log "Modules loaded"
}

# ============================================
# Setup loop devices
# ============================================

setup_loop_devices() {
    log "Setting up loop devices..."
    
    [ -c /dev/loop-control ] || mknod -m 660 /dev/loop-control c 10 237
    
    for i in 0 1 2 3 4 5 6 7; do
        [ -b "/dev/loop$i" ] || mknod -m 660 "/dev/loop$i" b 7 "$i"
    done
    
    log "Loop devices ready"
}

# ============================================
# Parse kernel command line
# ============================================

parse_cmdline() {
    [ -r /proc/cmdline ] || return

    for param in $(cat /proc/cmdline); do
        case "$param" in
            debug)
                DEBUG_MODE=1
                set -x
                ;;
            rootdelay=*)
                sleep "${param#rootdelay=}"
                ;;
            init=*)
                OVERRIDE_INIT="${param#init=}"
                log "Init override: $OVERRIDE_INIT"
                ;;
        esac
    done
}

# ============================================
# Check if binary is valid ELF and has deps
# ============================================

check_binary() {
    local binary="$1"
    local root="$2"
    
    [ -f "$binary" ] || {
        error "  File not found: $binary"
        return 1
    }
    
    [ -x "$binary" ] || {
        error "  Not executable: $binary"
        return 1
    }
    
    # Check ELF magic
    local magic
    magic=$(dd if="$binary" bs=4 count=1 2>/dev/null | hexdump -C | head -1)
    echo "$magic" | grep -q "7f 45 4c 46" || {
        error "  Not an ELF file: $binary"
        return 1
    }
    
    # Get interpreter (dynamic linker)
    local interp
    interp=$(readelf -l "$binary" 2>/dev/null | grep "interpreter" | sed -E 's/.*\[(.*)\].*/\1/')
    
    if [ -n "$interp" ]; then
        log "  Dynamic binary, interpreter: $interp"
        
        # Check if interpreter exists in new root
        if [ ! -f "${root}${interp}" ]; then
            error "  Missing interpreter: ${root}${interp}"
            return 1
        fi
        
        # Check some critical libraries
        local missing_libs=0
        for lib in $(ldd "$binary" 2>/dev/null | grep "not found" | awk '{print $1}'); do
            error "  Missing library: $lib"
            missing_libs=1
        done
        
        [ $missing_libs -eq 1 ] && return 1
        
        log "  Library dependencies OK"
    else
        log "  Static binary, no interpreter needed"
    fi
    
    return 0
}

# ============================================
# Find boot media
# ============================================

find_boot_media() {
    local BOOT_MNT="/bootmnt"
    
    log "Searching for boot media..."
    mkdir -p "$BOOT_MNT"
    
    # Try CDROM first
    for dev in /dev/sr0 /dev/cdrom /dev/dvd; do
        [ -b "$dev" ] || continue
        log "Trying CDROM: $dev"
        
        if mount -t iso9660 -o ro "$dev" "$BOOT_MNT" 2>/dev/null; then
            if [ -f "$BOOT_MNT/boot/lfs.squashfs" ]; then
                log "Found on CDROM: $dev"
                echo "$dev"
                return 0
            fi
            umount "$BOOT_MNT" 2>/dev/null
        fi
    done
    
    # Try all partitions
    for part in $(ls /dev/sd[a-z][0-9]* /dev/hd[a-z][0-9]* 2>/dev/null); do
        [ -b "$part" ] || continue
        log "Trying partition: $part"
        
        for fstype in vfat ext4 iso9660; do
            if mount -t "$fstype" -o ro "$part" "$BOOT_MNT" 2>/dev/null; then
                if [ -f "$BOOT_MNT/boot/lfs.squashfs" ] || [ -f "$BOOT_MNT/lfs.squashfs" ]; then
                    log "Found on $part ($fstype)"
                    echo "$part"
                    return 0
                fi
                umount "$BOOT_MNT" 2>/dev/null
            fi
        done
    done
    
    # Try whole disks (USB floppy style)
    for disk in /dev/sd[a-z] /dev/hd[a-z]; do
        [ -b "$disk" ] || continue
        log "Trying disk: $disk"
        
        if mount -t vfat -o ro "$disk" "$BOOT_MNT" 2>/dev/null; then
            if [ -f "$BOOT_MNT/lfs.squashfs" ]; then
                log "Found on disk: $disk"
                echo "$disk"
                return 0
            fi
            umount "$BOOT_MNT" 2>/dev/null
        fi
    done
    
    error "No boot media found"
    return 1
}

# ============================================
# Mount root filesystem
# ============================================

mount_root() {
    local BOOT_MNT="/bootmnt"
    local SQUASH_MNT="/squashfs"
    local ROOT_MNT="/newroot"
    local COW_DIR="/cow"
    
    log "Mounting root filesystem..."
    
    mkdir -p "$BOOT_MNT" "$SQUASH_MNT" "$ROOT_MNT" "$COW_DIR"
    
    # Find and mount boot media
    BOOT_DEV=$(find_boot_media)
    [ -n "$BOOT_DEV" ] || return 1
    
    # Mount boot media if not already mounted
    if ! mountpoint -q "$BOOT_MNT"; then
        mount -t auto -o ro "$BOOT_DEV" "$BOOT_MNT" || {
            error "Cannot mount $BOOT_DEV"
            return 1
        }
    fi
    
    log "Boot media mounted at $BOOT_MNT"
    
    # Find squashfs file
    SQUASHFS_FILE=""
    for f in "$BOOT_MNT/boot/lfs.squashfs" "$BOOT_MNT/lfs.squashfs" "$BOOT_MNT/rootfs.squashfs"; do
        if [ -f "$f" ]; then
            SQUASHFS_FILE="$f"
            break
        fi
    done
    
    if [ -z "$SQUASHFS_FILE" ]; then
        error "No squashfs file found"
        ls -la "$BOOT_MNT/boot/" 2>/dev/null
        ls -la "$BOOT_MNT/" 2>/dev/null
        return 1
    fi
    
    log "Squashfs file: $SQUASHFS_FILE"
    ls -lh "$SQUASHFS_FILE"
    
    # Mount squashfs
    log "Mounting squashfs..."
    mount -t squashfs -o loop "$SQUASHFS_FILE" "$SQUASH_MNT" || {
        error "Cannot mount squashfs"
        return 1
    }
    
    # Verify squashfs content
    if [ -z "$(ls -A "$SQUASH_MNT" 2>/dev/null)" ]; then
        error "Squashfs is empty"
        return 1
    fi
    
    log "Squashfs mounted, contents: $(ls "$SQUASH_MNT" | head -5)"
    
    # Setup overlay writable layer
    log "Setting up overlay..."
    mount -t tmpfs -o mode=755 tmpfs "$COW_DIR" || {
        error "Cannot mount tmpfs for overlay"
        return 1
    }
    
    mkdir -p "$COW_DIR/upper" "$COW_DIR/work"
    
    # Mount overlay
    mount -t overlay overlay \
        -o lowerdir="$SQUASH_MNT",upperdir="$COW_DIR/upper",workdir="$COW_DIR/work" \
        "$ROOT_MNT" || {
        error "Cannot mount overlay"
        return 1
    }
    
    log "Overlay mounted at $ROOT_MNT"
    
    # Create directory structure
    mkdir -p "$ROOT_MNT"/{dev,proc,sys,run,tmp,etc,root,home,var,usr,mnt,media}
    mkdir -p "$ROOT_MNT"/{bin,sbin,lib,lib64,opt,srv,boot}
    
    # IMPORTANT: Bind mount pseudo filesystems (use --rbind for recursive)
    log "Bind mounting pseudo filesystems..."
    
    mount --rbind /dev "$ROOT_MNT/dev" 2>/dev/null || {
        warn "Cannot bind /dev, mounting fresh"
        mount -t devtmpfs devtmpfs "$ROOT_MNT/dev"
        cp -a /dev/* "$ROOT_MNT/dev/" 2>/dev/null
    }
    
    mount --rbind /proc "$ROOT_MNT/proc" 2>/dev/null || {
        warn "Cannot bind /proc, mounting fresh"
        mount -t proc proc "$ROOT_MNT/proc"
    }
    
    mount --rbind /sys "$ROOT_MNT/sys" 2>/dev/null || {
        warn "Cannot bind /sys, mounting fresh"
        mount -t sysfs sysfs "$ROOT_MNT/sys"
    }
    
    mount --rbind /run "$ROOT_MNT/run" 2>/dev/null || {
        mount -t tmpfs tmpfs "$ROOT_MNT/run"
    }
    
    mount --rbind /tmp "$ROOT_MNT/tmp" 2>/dev/null || {
        mount -t tmpfs tmpfs "$ROOT_MNT/tmp"
    }
    
    # Devpts
    mkdir -p "$ROOT_MNT/dev/pts"
    mount -t devpts devpts "$ROOT_MNT/dev/pts" -o gid=5,mode=620
    
    # Create critical device nodes
    for dev in null zero console tty random urandom; do
        [ -e "$ROOT_MNT/dev/$dev" ] || {
            case "$dev" in
                null)    mknod -m 666 "$ROOT_MNT/dev/null" c 1 3 ;;
                zero)    mknod -m 666 "$ROOT_MNT/dev/zero" c 1 5 ;;
                console) mknod -m 600 "$ROOT_MNT/dev/console" c 5 1 ;;
                tty)     mknod -m 666 "$ROOT_MNT/dev/tty" c 5 0 ;;
                random)  mknod -m 666 "$ROOT_MNT/dev/random" c 1 8 ;;
                urandom) mknod -m 666 "$ROOT_MNT/dev/urandom" c 1 9 ;;
            esac
        }
    done
    
    # Bind mount boot media
    mkdir -p "$ROOT_MNT/mnt/bootmedia"
    mount --bind "$BOOT_MNT" "$ROOT_MNT/mnt/bootmedia" 2>/dev/null
    
    log "Root filesystem ready"
    echo "$ROOT_MNT"
    return 0
}

# ============================================
# Find and verify init
# ============================================

find_root_init() {
    local ROOT_MNT="$1"
    
    log "Searching for init in $ROOT_MNT..."
    
    # List what's available
    log "Available binaries:"
    ls -la "$ROOT_MNT/sbin/" 2>/dev/null | head -10
    ls -la "$ROOT_MNT/bin/" 2>/dev/null | head -10
    
    # Override from cmdline
    if [ -n "$OVERRIDE_INIT" ]; then
        if [ -x "$ROOT_MNT$OVERRIDE_INIT" ]; then
            log "Using override: $OVERRIDE_INIT"
            if check_binary "$ROOT_MNT$OVERRIDE_INIT" "$ROOT_MNT"; then
                echo "$OVERRIDE_INIT"
                return 0
            fi
        else
            error "Override init not executable: $ROOT_MNT$OVERRIDE_INIT"
        fi
    fi
    
    # Try common init paths
    for init in /sbin/init /usr/sbin/init /bin/init /init; do
        if [ -x "$ROOT_MNT$init" ]; then
            log "Checking init: $init"
            if check_binary "$ROOT_MNT$init" "$ROOT_MNT"; then
                log "Valid init found: $init"
                echo "$init"
                return 0
            else
                warn "Init $init is not valid"
            fi
        fi
    done
    
    # Try systemd
    for init in /usr/lib/systemd/systemd /lib/systemd/systemd; do
        if [ -x "$ROOT_MNT$init" ]; then
            log "Checking systemd: $init"
            if check_binary "$ROOT_MNT$init" "$ROOT_MNT"; then
                log "Valid systemd found: $init"
                echo "$init"
                return 0
            fi
        fi
    done
    
    # Fallback to shell
    if [ -x "$ROOT_MNT/bin/sh" ]; then
        warn "No valid init found, falling back to /bin/sh"
        echo "/bin/sh"
        return 0
    fi
    
    return 1
}

# ============================================
# Main
# ============================================

log "========================================="
log "LeakOS Live Initramfs Starting"
log "========================================="
log "Kernel: $(uname -r)"

mount_base
parse_cmdline
load_modules
setup_loop_devices

# Optional: start udev only if needed
if [ "$DEBUG_MODE" -eq 0 ]; then
    # Start udev briefly
    if [ -x /sbin/udevd ]; then
        /sbin/udevd --daemon
        udevadm trigger
        udevadm settle --timeout=10
    fi
fi

# Wait for devices
sleep 2

# Mount root
ROOT_MNT=$(mount_root)
if [ -z "$ROOT_MNT" ]; then
    error "Failed to mount root filesystem"
    emergency_shell
fi

# Show mounts
log "Mounts in new root:"
mount | grep -E "$ROOT_MNT|squash|overlay" | head -10

# Find init
ROOT_INIT=$(find_root_init "$ROOT_MNT")
if [ -z "$ROOT_INIT" ]; then
    error "No init found in $ROOT_MNT"
    emergency_shell
fi

log "========================================="
log "Switching to new root: $ROOT_MNT"
log "Init: $ROOT_INIT"
log "========================================="

# Clean up
killall udevd 2>/dev/null

# Try switch_root
exec switch_root "$ROOT_MNT" "$ROOT_INIT"

# If we get here, switch_root failed
error "switch_root failed"

# Try pivot_root as fallback
log "Trying pivot_root fallback..."
mkdir -p "$ROOT_MNT/oldroot"
pivot_root "$ROOT_MNT" "$ROOT_MNT/oldroot" 2>/dev/null
exec chroot . "$ROOT_INIT" 2>/dev/null

emergency_shell
