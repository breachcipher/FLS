#!/bin/sh
# LeakOS Live Initramfs Init Script
# Fixed v4 - Proper mount order and error handling

export PATH=/usr/bin:/usr/sbin:/bin:/sbin
export HOME=/

OVERRIDE_INIT=""

# ============================================
# Fungsi utilitas
# ============================================

log() {
    echo "[INIT] $*" > /dev/kmsg 2>/dev/null
    echo "[INIT] $*"
}

warn() {
    echo "[WARN] $*" > /dev/kmsg 2>/dev/null
    echo "[WARN] $*"
}

error() {
    echo "[ERROR] $*" > /dev/kmsg 2>/dev/null
    echo "[ERROR] $*"
}

emergency_shell() {
    echo ""
    echo "========================================"
    echo "  EMERGENCY SHELL - LeakOS Debug"
    echo "========================================"
    echo "Tips debug:"
    echo "  lsblk | blkid | mount | dmesg"
    echo "  ls /bootmnt/boot/"
    echo "  mount -t squashfs -o loop /bootmnt/boot/lfs.squashfs /squashfs"
    echo "  ls /squashfs"
    echo "  ls /newroot/sbin/"
    echo "  file /newroot/sbin/init"
    echo "  ls /newroot/lib/ld-* /newroot/lib64/ld-*"
    echo "  cat /proc/mounts"
    echo "========================================"
    echo ""
    exec /bin/sh
}

# ============================================
# Mount basic filesystems
# ============================================

mount_base() {
    log "Mounting base filesystems..."

    mount -t devtmpfs devtmpfs /dev 2>/dev/null || \
        mount -t tmpfs tmpfs /dev 2>/dev/null || \
        error "devtmpfs failed"

    mount -t proc proc /proc       2>/dev/null || error "proc failed"
    mount -t sysfs sysfs /sys      2>/dev/null || error "sysfs failed"
    mount -t tmpfs tmpfs /run      2>/dev/null || warn "tmpfs /run failed"
    mount -t tmpfs tmpfs /tmp      2>/dev/null || warn "tmpfs /tmp failed"

    mkdir -p /dev/pts 2>/dev/null
    mount -t devpts devpts /dev/pts -o gid=5,mode=620 2>/dev/null || warn "devpts failed"

    # Pastikan device node penting ada
    [ -c /dev/null ]    || mknod -m 666 /dev/null    c 1 3
    [ -c /dev/console ] || mknod -m 600 /dev/console c 5 1
    [ -c /dev/tty ]     || mknod -m 666 /dev/tty     c 5 0
    [ -c /dev/tty1 ]    || mknod -m 600 /dev/tty1    c 4 1
    [ -c /dev/tty2 ]    || mknod -m 600 /dev/tty2    c 4 2
    [ -c /dev/urandom ] || mknod -m 666 /dev/urandom c 1 9
    [ -c /dev/random ]  || mknod -m 666 /dev/random  c 1 8

    log "Base filesystems ready"
}

# ============================================
# Load kernel modules
# ============================================

load_modules() {
    log "Loading kernel modules..."

    for mod in squashfs overlay loop; do
        modprobe -q "$mod" 2>/dev/null && log "  Loaded: $mod" || warn "  Failed: $mod"
    done

    for mod in vfat exfat iso9660 ext4 ext3 ext2 xfs btrfs; do
        modprobe -q "$mod" 2>/dev/null
    done

    for mod in usb_storage sr_mod ahci nvme virtio_blk mmc_block; do
        modprobe -q "$mod" 2>/dev/null
    done

    for mod in xhci_hcd ehci_hcd uhci_hcd; do
        modprobe -q "$mod" 2>/dev/null
    done

    log "Modules loaded"
}

# ============================================
# Setup loop devices
# ============================================

setup_loop_devices() {
    log "Setting up loop devices..."
    for i in 0 1 2 3 4 5 6 7; do
        [ -b "/dev/loop$i" ] || mknod -m 660 "/dev/loop$i" b 7 "$i" 2>/dev/null
    done
}

# ============================================
# Start udev
# ============================================

start_udev() {
    log "Starting udev..."

    UDEVD=""
    for p in /usr/lib/systemd/systemd-udevd /usr/lib/udev/udevd /sbin/udevd /usr/sbin/udevd; do
        [ -x "$p" ] && UDEVD="$p" && break
    done

    if [ -z "$UDEVD" ]; then
        warn "udevd not found, skipping"
        return
    fi

    $UDEVD --daemon --resolve-names=never 2>/dev/null
    udevadm trigger --action=add 2>/dev/null
    udevadm settle --timeout=30 2>/dev/null

    log "udev ready"
}

# ============================================
# Parse kernel command line
# ============================================

parse_cmdline() {
    [ -r /proc/cmdline ] || return

    for param in $(cat /proc/cmdline); do
        case "$param" in
            debug)
                log "Debug mode enabled"
                set -x
                ;;
            rootdelay=*)
                delay="${param#rootdelay=}"
                log "Root delay: ${delay}s"
                sleep "$delay"
                ;;
            init=*)
                OVERRIDE_INIT="${param#init=}"
                log "Init override dari cmdline: $OVERRIDE_INIT"
                ;;
            single|s)
                log "Single user mode"
                OVERRIDE_INIT="/bin/sh"
                ;;
        esac
    done
}

# ============================================
# Cari boot media dengan lfs.squashfs
# ============================================

find_boot_media() {
    local BOOT_MNT="/bootmnt"
    local timeout=60
    local elapsed=0

    log "Searching for boot media (timeout: ${timeout}s)..."
    mkdir -p "$BOOT_MNT" 2>/dev/null

    # First, try to find already mounted boot media
    if mountpoint -q "$BOOT_MNT" 2>/dev/null && [ -f "$BOOT_MNT/boot/lfs.squashfs" ]; then
        log "Boot media already mounted at $BOOT_MNT"
        # Find the device mounted at bootmnt
        BOOT_DEV=$(mount | grep " $BOOT_MNT " | cut -d' ' -f1)
        echo "$BOOT_DEV"
        return 0
    fi

    while [ $elapsed -lt $timeout ]; do
        # Scan all block devices
        for sysdev in /sys/block/*; do
            [ -e "$sysdev" ] || continue
            dev=$(basename "$sysdev")
            
            # Skip virtual devices
            case "$dev" in
                loop*|ram*|dm-*) continue ;;
            esac

            # Check partitions first
            for part in /dev/${dev}p[0-9]* /dev/${dev}[0-9]*; do
                [ -b "$part" ] || continue
                
                # Try different filesystems
                for fstype in iso9660 udf vfat exfat ext4 ext3 ext2; do
                    if mount -t "$fstype" -o ro "$part" "$BOOT_MNT" 2>/dev/null; then
                        if [ -f "$BOOT_MNT/boot/lfs.squashfs" ]; then
                            log "Found boot media: $part (partition, $fstype)"
                            echo "$part"
                            return 0
                        fi
                        umount "$BOOT_MNT" 2>/dev/null
                    fi
                done
            done

            # Check whole disk (for optical media)
            if [ -b "/dev/$dev" ]; then
                for fstype in iso9660 udf; do
                    if mount -t "$fstype" -o ro "/dev/$dev" "$BOOT_MNT" 2>/dev/null; then
                        if [ -f "$BOOT_MNT/boot/lfs.squashfs" ]; then
                            log "Found boot media: /dev/$dev (whole disk, $fstype)"
                            echo "/dev/$dev"
                            return 0
                        fi
                        umount "$BOOT_MNT" 2>/dev/null
                    fi
                done
            fi
        done

        sleep 2
        elapsed=$((elapsed + 2))
        [ $((elapsed % 10)) -eq 0 ] && log "Still searching... (${elapsed}s)"
    done

    error "Boot media not found after ${timeout}s"
    return 1
}

# ============================================
# Verifikasi ELF binary
# ============================================

verify_elf() {
    local binary="$1"
    local root="$2"

    # Check if file exists
    [ -f "$binary" ] || {
        error "  File not found: $binary"
        return 1
    }

    # Check magic bytes ELF
    if ! dd if="$binary" bs=4 count=1 2>/dev/null | grep -q $'\x7fELF'; then
        error "  $binary: Not an ELF binary!"
        file "$binary" 2>/dev/null
        return 1
    fi

    # Check dynamic linker
    local interp
    interp=$(readelf -l "$binary" 2>/dev/null | grep "interpreter" | sed 's/.*\[\(.*\)\]/\1/')

    if [ -n "$interp" ]; then
        log "  Dynamic linker: $interp"
        if [ ! -f "${root}${interp}" ]; then
            error "  MISSING dynamic linker: ${root}${interp}"
            return 1
        fi
        log "  Dynamic linker OK"
    else
        log "  Static binary"
    fi

    return 0
}

# ============================================
# Mount root filesystem (squashfs + overlay)
# ============================================

mount_root() {
    local BOOT_MNT="/bootmnt"
    local SQUASH_MNT="/squashfs"
    local ROOT_MNT="/newroot"
    local COW_DIR="/cow"
    local UPPER_DIR="$COW_DIR/upper"
    local WORK_DIR="$COW_DIR/work"

    log "Mounting root filesystem..."
    
    # Create all necessary directories
    mkdir -p "$BOOT_MNT" "$SQUASH_MNT" "$ROOT_MNT" "$COW_DIR"
    mkdir -p "$ROOT_MNT"/{dev,proc,sys,run,tmp,etc,root,home,var,usr,bin,sbin,lib,lib64,mnt,media,opt,srv,boot}

    # Find boot media
    BOOT_DEV=$(find_boot_media)
    if [ -z "$BOOT_DEV" ]; then
        error "Boot media with lfs.squashfs not found!"
        echo "Available block devices:"
        lsblk 2>/dev/null || cat /proc/partitions
        return 1
    fi

    log "Boot device: $BOOT_DEV"

    # Check if boot media is already mounted
    if ! mountpoint -q "$BOOT_MNT" 2>/dev/null; then
        log "Mounting boot media..."
        if ! mount -t auto -o ro "$BOOT_DEV" "$BOOT_MNT"; then
            error "Failed to mount $BOOT_DEV"
            return 1
        fi
    else
        log "Boot media already mounted at $BOOT_MNT"
    fi

    # Verify lfs.squashfs exists
    if [ ! -f "$BOOT_MNT/boot/lfs.squashfs" ]; then
        error "lfs.squashfs not found in $BOOT_MNT/boot/"
        log "Contents of $BOOT_MNT/boot/:"
        ls -la "$BOOT_MNT/boot/" 2>/dev/null
        return 1
    fi

    log "lfs.squashfs found at $BOOT_MNT/boot/lfs.squashfs"
    ls -lh "$BOOT_MNT/boot/lfs.squashfs"

    # Mount squashfs
    log "Mounting squashfs..."
    if ! mount -t squashfs -o loop "$BOOT_MNT/boot/lfs.squashfs" "$SQUASH_MNT"; then
        error "Failed to mount squashfs"
        return 1
    fi

    log "Squashfs mounted at $SQUASH_MNT"

    # Verify squashfs is not empty
    if [ -z "$(ls -A $SQUASH_MNT 2>/dev/null)" ]; then
        error "Squashfs appears empty after mount!"
        return 1
    fi

    log "Squashfs contents: $(ls $SQUASH_MNT | head -5)..."

    # Mount tmpfs for overlay (writable layer)
    log "Setting up overlay writable layer..."
    if ! mount -t tmpfs -o mode=755 tmpfs "$COW_DIR"; then
        error "Failed to mount tmpfs for overlay"
        return 1
    fi

    mkdir -p "$UPPER_DIR" "$WORK_DIR"

    # Mount overlay - THIS IS THE ROOT FILESYSTEM
    log "Mounting overlay filesystem..."
    if ! mount -t overlay overlay \
        -o lowerdir="$SQUASH_MNT",upperdir="$UPPER_DIR",workdir="$WORK_DIR" \
        "$ROOT_MNT"; then
        error "Failed to mount overlay"
        return 1
    fi

    log "Overlay mounted successfully at $ROOT_MNT"

    # NOW move the pseudo-filesystems (after overlay is mounted)
    log "Moving pseudo-filesystems to new root..."

    # Move /dev
    if mountpoint -q /dev; then
        mount --move /dev "$ROOT_MNT/dev" 2>/dev/null || {
            warn "Failed to move /dev, bind mounting instead"
            mount --bind /dev "$ROOT_MNT/dev" 2>/dev/null || {
                error "Cannot mount /dev in new root"
                return 1
            }
        }
    else
        mount -t devtmpfs devtmpfs "$ROOT_MNT/dev" 2>/dev/null || error "Cannot mount /dev"
    fi

    # Move /proc
    if mountpoint -q /proc; then
        mount --move /proc "$ROOT_MNT/proc" 2>/dev/null || {
            warn "Failed to move /proc, mounting fresh"
            mount -t proc proc "$ROOT_MNT/proc" 2>/dev/null || error "Cannot mount /proc"
        }
    else
        mount -t proc proc "$ROOT_MNT/proc" 2>/dev/null || error "Cannot mount /proc"
    fi

    # Move /sys
    if mountpoint -q /sys; then
        mount --move /sys "$ROOT_MNT/sys" 2>/dev/null || {
            warn "Failed to move /sys, mounting fresh"
            mount -t sysfs sysfs "$ROOT_MNT/sys" 2>/dev/null || error "Cannot mount /sys"
        }
    else
        mount -t sysfs sysfs "$ROOT_MNT/sys" 2>/dev/null || error "Cannot mount /sys"
    fi

    # Move /run
    if mountpoint -q /run; then
        mount --move /run "$ROOT_MNT/run" 2>/dev/null || {
            warn "Failed to move /run, mounting fresh"
            mount -t tmpfs tmpfs "$ROOT_MNT/run" 2>/dev/null || error "Cannot mount /run"
        }
    else
        mount -t tmpfs tmpfs "$ROOT_MNT/run" 2>/dev/null || error "Cannot mount /run"
    fi

    # Mount devpts in the new root
    mkdir -p "$ROOT_MNT/dev/pts"
    mount -t devpts devpts "$ROOT_MNT/dev/pts" -o gid=5,mode=620 2>/dev/null || \
        warn "devpts in newroot failed"

    # Mount tmpfs in new root for /tmp
    mount -t tmpfs tmpfs "$ROOT_MNT/tmp" 2>/dev/null || warn "tmpfs in newroot failed"

    # Bind mount boot media into rootfs for access
    mkdir -p "$ROOT_MNT/mnt/bootmedia" 2>/dev/null
    mount --bind "$BOOT_MNT" "$ROOT_MNT/mnt/bootmedia" 2>/dev/null || \
        warn "Failed to bind mount boot media"

    # Ensure critical device nodes exist in new root
    log "Creating device nodes in new root..."
    [ -c "$ROOT_MNT/dev/null" ] || mknod -m 666 "$ROOT_MNT/dev/null" c 1 3 2>/dev/null
    [ -c "$ROOT_MNT/dev/zero" ] || mknod -m 666 "$ROOT_MNT/dev/zero" c 1 5 2>/dev/null
    [ -c "$ROOT_MNT/dev/random" ] || mknod -m 666 "$ROOT_MNT/dev/random" c 1 8 2>/dev/null
    [ -c "$ROOT_MNT/dev/urandom" ] || mknod -m 666 "$ROOT_MNT/dev/urandom" c 1 9 2>/dev/null
    [ -c "$ROOT_MNT/dev/tty" ] || mknod -m 666 "$ROOT_MNT/dev/tty" c 5 0 2>/dev/null
    [ -c "$ROOT_MNT/dev/console" ] || mknod -m 600 "$ROOT_MNT/dev/console" c 5 1 2>/dev/null

    log "Root filesystem ready at $ROOT_MNT"
    
    # Show mount points for debugging
    log "Current mounts in new root:"
    mount | grep "$ROOT_MNT" | head -5

    echo "$ROOT_MNT"
    return 0
}

# ============================================
# Dump info debug rootfs
# ============================================

dump_rootfs_info() {
    local ROOT_MNT="$1"

    log "=== DEBUG ROOTFS INFO ==="
    
    log "Contents of $ROOT_MNT:"
    ls -la "$ROOT_MNT/" 2>/dev/null | head -10
    
    log "Contents of $ROOT_MNT/sbin/ (first 10):"
    ls -la "$ROOT_MNT/sbin/" 2>/dev/null | head -10
    
    log "Contents of $ROOT_MNT/bin/ (first 10):"
    ls -la "$ROOT_MNT/bin/" 2>/dev/null | head -10

    log "Dynamic linker in rootfs:"
    ls "$ROOT_MNT/lib/"ld-* 2>/dev/null
    ls "$ROOT_MNT/lib64/"ld-* 2>/dev/null
    ls "$ROOT_MNT/usr/lib/"ld-* 2>/dev/null

    log "Checking /sbin/init:"
    if [ -f "$ROOT_MNT/sbin/init" ]; then
        file "$ROOT_MNT/sbin/init" 2>/dev/null || log "  (file command not available)"
        ls -l "$ROOT_MNT/sbin/init"
    else
        log "  /sbin/init not found"
    fi
    
    log "Checking alternative init locations:"
    for init in /init /bin/init /usr/sbin/init /usr/bin/init; do
        [ -f "$ROOT_MNT$init" ] && log "  Found: $init"
    done
    
    log "=== END DEBUG INFO ==="
}

# ============================================
# Cari dan verifikasi init di new root
# ============================================

find_root_init() {
    local ROOT_MNT="$1"

    log "Searching for init in $ROOT_MNT..."

    # Override from cmdline (init=/path)
    if [ -n "$OVERRIDE_INIT" ]; then
        if [ -x "$ROOT_MNT$OVERRIDE_INIT" ]; then
            log "Using cmdline init: $OVERRIDE_INIT"
            echo "$OVERRIDE_INIT"
            return 0
        else
            error "Override init not found/executable: $ROOT_MNT$OVERRIDE_INIT"
        fi
    fi

    # Check init candidates in order
    for init in \
        /sbin/init \
        /usr/sbin/init \
        /bin/init \
        /usr/bin/init \
        /usr/lib/systemd/systemd \
        /lib/systemd/systemd \
        /sbin/openrc-init \
        /init
    do
        if [ -x "$ROOT_MNT$init" ]; then
            log "Checking init candidate: $init"
            if verify_elf "$ROOT_MNT$init" "$ROOT_MNT"; then
                log "Init valid: $init"
                echo "$init"
                return 0
            else
                warn "Init $init failed verification, skipping..."
            fi
        fi
    done

    # Fallback to /bin/sh
    if [ -x "$ROOT_MNT/bin/sh" ]; then
        warn "No valid init found, falling back to /bin/sh"
        echo "/bin/sh"
        return 0
    fi

    error "No init or shell found in rootfs!"
    return 1
}

# ============================================
# Cleanup sebelum switch_root
# ============================================

cleanup() {
    log "Cleaning up initramfs..."
    
    # Kill udev daemons
    killall udevd 2>/dev/null
    killall systemd-udevd 2>/dev/null
    
    # Unmount unnecessary mounts
    umount /dev/pts 2>/dev/null
    umount /tmp 2>/dev/null
    
    # Wait a bit for cleanup
    sleep 1
    
    log "Cleanup complete"
}

# ============================================
# MAIN
# ============================================

log "========================================="
log "=== LeakOS Live Initramfs Starting ==="
log "========================================="
log "Kernel: $(uname -r)"
log "Date: $(date)"

# Initialize basic system
mount_base
parse_cmdline
load_modules
setup_loop_devices
start_udev

# Give time for devices to be recognized
sleep 2

# Mount root filesystem
ROOT_MNT=$(mount_root)
if [ -z "$ROOT_MNT" ] || [ ! -d "$ROOT_MNT" ]; then
    error "Failed to mount root filesystem!"
    emergency_shell
fi

# Dump debug info
dump_rootfs_info "$ROOT_MNT"

# Find init
ROOT_INIT=$(find_root_init "$ROOT_MNT")
if [ -z "$ROOT_INIT" ]; then
    error "No valid init found in $ROOT_MNT!"
    emergency_shell
fi

# Cleanup initramfs
cleanup

log "========================================="
log "=== Switching to new root ==="
log "=== Init: $ROOT_INIT ==="
log "========================================="

# Execute switch_root
exec switch_root "$ROOT_MNT" "$ROOT_INIT"

# If we get here, switch_root failed
error "switch_root FAILED with exit code $?"
error "This should never happen!"

# Try to run init directly as fallback
if [ -x "$ROOT_MNT$ROOT_INIT" ]; then
    log "Attempting direct chroot..."
    exec chroot "$ROOT_MNT" "$ROOT_INIT"
fi

# Emergency shell if all else fails
emergency_shell
