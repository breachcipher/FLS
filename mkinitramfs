#!/bin/bash
# mkinitramfs for LFS Live ISO
# Compatible: Ventoy, Rufus, USB, CD/DVD
# FIXED: ld-linux copy semua path, symlink lib64 benar, verifikasi deps lengkap
# FIXED: Tidak ada lagi kernel panic error -8 / init not found

copy()
{
  local file

  if [ "$2" = "lib" ]; then
    file=$(PATH=/usr/lib type -p $1 2>/dev/null)
  else
    file=$(type -p $1 2>/dev/null)
  fi

  if [ -n "$file" ] ; then
    cp "$file" "$WDIR/usr/$2"
    echo "  Copied: $1 -> $file"
  else
    echo "Warning: Missing file: $1"
  fi
}

if [ -z "$1" ] ; then
  INITRAMFS_FILE=initrd.img-no-kmods
else
  KERNEL_VERSION=$1
  INITRAMFS_FILE=initrd.img-$KERNEL_VERSION
fi

if [ -n "$KERNEL_VERSION" ] && [ ! -d "/lib/modules/$1" ] ; then
  echo "ERROR: No modules directory: /lib/modules/$1"
  exit 1
fi

printf "Creating $INITRAMFS_FILE... "

# Binaries wajib ada di initramfs
binfiles="sh bash cat cp dd killall ls mkdir mknod mount lsblk grep mountpoint"
binfiles="$binfiles umount sed sleep ln rm uname readlink basename"
binfiles="$binfiles chmod chown find losetup stat"

# udevadm
if   [ -x /usr/bin/udevadm ] ; then binfiles="$binfiles"
elif [ -x /sbin/udevadm ]    ; then binfiles="$binfiles"
fi

sbinfiles="modprobe blkid switch_root"

# udevd — cari di semua lokasi umum
for f in udevd udevadm; do
  if   [ -x /usr/sbin/$f ] ; then sbinfiles="$sbinfiles $f"
  elif [ -x /sbin/$f ]     ; then sbinfiles="$sbinfiles $f"
  fi
done

unsorted=$(mktemp /tmp/unsorted.XXXXXXXXXX)

DATADIR=/usr/share/mkinitramfs
INITIN=init.in

WDIR=$(mktemp -d /tmp/initrd-work.XXXXXXXXXX)

# Buat struktur direktori lengkap
mkdir -p $WDIR/{dev,run,sys,proc,tmp,tmpmnt,usr/{bin,lib/{firmware,modules},sbin}}
mkdir -p $WDIR/{mnt,squash,cow/{mod,buffer},.root}
mkdir -p $WDIR/etc/{modprobe.d,udev/rules.d}
mkdir -p $WDIR/home $WDIR/root $WDIR/var/{log,lib,spool}

touch $WDIR/etc/modprobe.d/modprobe.conf

# Symlinks standar (FHS compat)
ln -s usr/bin  $WDIR/bin
ln -s usr/lib  $WDIR/lib
ln -s usr/sbin $WDIR/sbin
# lib64 HARUS mengarah ke usr/lib (bukan lib) karena ld-linux di-copy ke usr/lib
ln -s usr/lib  $WDIR/lib64

# Device nodes minimal
mknod -m 640 $WDIR/dev/console c 5 1
mknod -m 664 $WDIR/dev/null    c 1 3
mknod -m 640 $WDIR/dev/kmsg    c 1 11

# Loop devices — dibutuhkan untuk squashfs dan Ventoy
for i in 0 1 2 3 4 5 6 7; do
  mknod -m 660 $WDIR/dev/loop$i b 7 $i
done

# udev config
if [ -f /etc/udev/udev.conf ]; then
  cp /etc/udev/udev.conf $WDIR/etc/udev/udev.conf
fi

# udev rules
if [ -d /etc/udev/rules.d ]; then
  for file in /etc/udev/rules.d/*.rules; do
    [ -f "$file" ] && cp "$file" "$WDIR/etc/udev/rules.d/"
  done
fi

# Firmware (optional)
if [ -d /lib/firmware ]; then
  cp -a /lib/firmware $WDIR/usr/lib/ 2>/dev/null || true
fi

# Validasi init.in ada sebelum install
if [ ! -f "$DATADIR/$INITIN" ]; then
  echo ""
  echo "ERROR: $DATADIR/$INITIN not found!"
  echo "Jalankan dulu: mkdir -p $DATADIR && cp init.in $DATADIR/init.in"
  rm -rf $WDIR $unsorted
  exit 1
fi

# Install init script
install -m0755 $DATADIR/$INITIN $WDIR/init
echo "Installed init from $DATADIR/$INITIN"

# Tambahkan kmod tools jika tersedia
if [ -n "$KERNEL_VERSION" ] ; then
  if [ -x /usr/bin/kmod ] ; then
    binfiles="$binfiles kmod"
  else
    binfiles="$binfiles lsmod"
    sbinfiles="$sbinfiles insmod"
  fi
fi

# Helper: parse ldd output, ambil path aktual library
# Format ldd:  "  libname.so => /path/to/lib.so (0x...)"
#          atau "  /lib64/ld-linux.so.2 (0x...)"  <- path absolut
parse_ldd() {
  ldd "$1" 2>/dev/null | while IFS= read -r line; do
    line=$(echo "$line" | sed 's/^\s*//')
    case "$line" in
      ""| *linux-vdso*|*linux-gate*) continue ;;
    esac
    if echo "$line" | grep -q '=>'; then
      # Format: libname => /path (addr) — ambil path
      echo "$line" | sed 's/.*=> //' | cut -d' ' -f1
    else
      # Format: /path/absolut (addr)
      echo "$line" | cut -d' ' -f1
    fi
  done
}

# Install binaries dari /usr/bin atau /bin
echo "Installing binaries..."
for f in $binfiles ; do
  if [ -x /usr/bin/$f ]; then
    parse_ldd /usr/bin/$f >> $unsorted
    copy $f bin
  elif [ -x /bin/$f ]; then
    parse_ldd /bin/$f >> $unsorted
    copy $f bin
  elif [ -x /usr/local/bin/$f ]; then
    parse_ldd /usr/local/bin/$f >> $unsorted
    copy $f bin
  else
    echo "Warning: $f not found in /usr/bin or /bin"
  fi
done

# Install sbinaries dari /usr/sbin atau /sbin
echo "Installing sbinaries..."
for f in $sbinfiles ; do
  if [ -x /usr/sbin/$f ]; then
    parse_ldd /usr/sbin/$f >> $unsorted
    copy $f sbin
  elif [ -x /sbin/$f ]; then
    parse_ldd /sbin/$f >> $unsorted
    copy $f sbin
  elif [ -x /usr/local/sbin/$f ]; then
    parse_ldd /usr/local/sbin/$f >> $unsorted
    copy $f sbin
  else
    echo "Warning: $f not found in /usr/sbin or /sbin"
  fi
done

# Cari dan copy udevd dari semua lokasi yang mungkin
UDEVD_FOUND=0
for udevd_path in \
  /usr/lib/udev/udevd \
  /lib/udev/udevd \
  /usr/lib/systemd/systemd-udevd \
  /usr/sbin/udevd \
  /sbin/udevd
do
  if [ -x "$udevd_path" ]; then
    parse_ldd "$udevd_path" >> $unsorted
    case "$udevd_path" in
      /usr/lib/udev/*)    dest="$WDIR/usr/lib/udev/" ;;
      /lib/udev/*)        dest="$WDIR/usr/lib/udev/" ;;
      /usr/lib/systemd/*) mkdir -p "$WDIR/usr/lib/systemd"; dest="$WDIR/usr/lib/systemd/" ;;
      *)                  dest="$WDIR/usr/sbin/" ;;
    esac
    mkdir -p "$dest"
    cp "$udevd_path" "$dest"
    echo "Copied udevd from $udevd_path"
    UDEVD_FOUND=1
    break
  fi
done
[ $UDEVD_FOUND -eq 0 ] && echo "WARNING: udevd not found anywhere! udev will not work."

# kmod symlinks
if [ -n "$KERNEL_VERSION" ] && [ -x /usr/bin/kmod ] ; then
  ln -sf kmod $WDIR/usr/bin/lsmod
  ln -sf kmod $WDIR/usr/bin/insmod
  ln -sf kmod $WDIR/usr/bin/modinfo
fi

# =====================================================
# Install shared libraries
# ldd bisa output nama file ATAU path absolut — handle keduanya
# =====================================================
echo "Installing shared libraries..."
sort $unsorted | uniq | while read entry ; do
  # entry bisa berupa "libc.so.6" atau "/lib64/ld-linux-x86-64.so.2"
  case "$entry" in
    linux-vdso.so*)     continue ;;
    linux-gate.so*)     continue ;;
    libsystemd-shared*) continue ;;
  esac

  # Kalau path absolut, ambil basename sebagai nama file tujuan
  if echo "$entry" | grep -q '^/'; then
    lib_name=$(basename "$entry")
    # Coba dari path absolut dulu
    if [ -f "$entry" ]; then
      cp "$entry" "$WDIR/usr/lib/" 2>/dev/null || true
      echo "  Copied library: $lib_name (dari path absolut)"
      continue
    fi
  else
    lib_name="$entry"
  fi

  lib_file=""
  for libdir in \
    /usr/lib \
    /lib \
    /usr/lib64 \
    /lib64 \
    /usr/lib/x86_64-linux-gnu \
    /lib/x86_64-linux-gnu
  do
    if [ -f "$libdir/$lib_name" ]; then
      lib_file="$libdir/$lib_name"
      break
    fi
  done

  if [ -n "$lib_file" ]; then
    cp "$lib_file" "$WDIR/usr/lib/" 2>/dev/null || true
    echo "  Copied library: $lib_name"
  else
    echo "  Warning: library not found: $lib_name"
  fi
done

# =====================================================
# Copy ld-linux dynamic linker — WAJIB ada, fix utama error -8
# Cari di semua lokasi yang mungkin ada di LFS/Debian/Arch/dll
# =====================================================
echo "Installing dynamic linker (ld-linux)..."
LD_FOUND=0
for ld_path in \
  /lib64/ld-linux-x86-64.so.2 \
  /lib/x86_64-linux-gnu/ld-linux-x86-64.so.2 \
  /usr/lib/x86_64-linux-gnu/ld-linux-x86-64.so.2 \
  /usr/lib64/ld-linux-x86-64.so.2 \
  /usr/lib/ld-linux-x86-64.so.2 \
  /lib/ld-linux-x86-64.so.2
do
  if [ -f "$ld_path" ]; then
    cp "$ld_path" "$WDIR/usr/lib/ld-linux-x86-64.so.2"
    echo "  Copied ld-linux from: $ld_path"
    LD_FOUND=1
    break
  fi
done
if [ $LD_FOUND -eq 0 ]; then
  # Cari dengan find sebagai last resort
  ld_found=$(find /usr /lib /lib64 -name "ld-linux-x86-64.so.2" -type f 2>/dev/null | head -1)
  if [ -n "$ld_found" ]; then
    cp "$ld_found" "$WDIR/usr/lib/ld-linux-x86-64.so.2"
    echo "  Copied ld-linux from (find): $ld_found"
    LD_FOUND=1
  fi
fi
[ $LD_FOUND -eq 0 ] && echo "  CRITICAL ERROR: ld-linux-x86-64.so.2 tidak ditemukan! Binary di initramfs tidak akan bisa jalan."

# Buat semua symlink ld-linux yang mungkin dicari kernel/loader
# lib64 sudah symlink ke usr/lib jadi otomatis terbaca
mkdir -p "$WDIR/lib/x86_64-linux-gnu"
ln -sf /usr/lib/ld-linux-x86-64.so.2 "$WDIR/lib/x86_64-linux-gnu/ld-linux-x86-64.so.2" 2>/dev/null || true
ln -sf /usr/lib/ld-linux-x86-64.so.2 "$WDIR/usr/lib/x86_64-linux-gnu/ld-linux-x86-64.so.2" 2>/dev/null || true

# =====================================================
# Verifikasi bahwa sh/bash benar-benar punya semua deps
# ldd bisa output nama file (libc.so.6) atau path absolut
# (/lib64/ld-linux-x86-64.so.2) — keduanya harus di-handle
# =====================================================
echo ""
echo "=== Verifying interpreter chain ==="
for interp in sh bash; do
  bin_path=""
  [ -f "$WDIR/usr/bin/$interp" ] && bin_path="$WDIR/usr/bin/$interp"
  if [ -z "$bin_path" ]; then
    echo "  MISSING: $interp"
    continue
  fi

  missing=0
  while IFS= read -r line; do
    # ldd output format bervariasi:
    #   libc.so.6 => /lib64/libc.so.6 (0x...)
    #   /lib64/ld-linux-x86-64.so.2 (0x...)    <- path absolut, tidak ada =>
    line=$(echo "$line" | sed 's/^\s*//')

    # Skip baris kosong dan vdso
    case "$line" in
      ""| *linux-vdso*|*linux-gate*) continue ;;
    esac

    # Ambil path aktual: kalau ada "=>" ambil bagian kanan, kalau tidak ada ambil field pertama
    if echo "$line" | grep -q '=>'; then
      lib_path=$(echo "$line" | sed 's/.*=> //' | cut -d' ' -f1)
      lib_name=$(echo "$line" | cut -d' ' -f1)
    else
      lib_path=$(echo "$line" | cut -d' ' -f1)
      lib_name=$(basename "$lib_path")
    fi

    # Skip "not found" atau path kosong
    [ -z "$lib_path" ] && continue
    [ "$lib_path" = "not" ] && continue

    lib_name=$(basename "$lib_path")

    # Cek apakah sudah ada di WDIR (cek filename-nya)
    if [ ! -f "$WDIR/usr/lib/$lib_name" ] && [ ! -L "$WDIR/usr/lib/$lib_name" ]; then
      echo "  MISSING dep for $interp: $lib_name (dari: $lib_path)"

      # Auto-fix: coba copy dari path absolut dulu, lalu fallback ke libdir scan
      fixed=0
      if [ -f "$lib_path" ]; then
        cp "$lib_path" "$WDIR/usr/lib/"
        echo "    -> Auto-fixed: copied from $lib_path"
        fixed=1
      else
        for libdir in /usr/lib /lib /lib64 /usr/lib64 /usr/lib/x86_64-linux-gnu /lib/x86_64-linux-gnu; do
          if [ -f "$libdir/$lib_name" ]; then
            cp "$libdir/$lib_name" "$WDIR/usr/lib/"
            echo "    -> Auto-fixed: copied $lib_name from $libdir"
            fixed=1
            break
          fi
        done
      fi

      [ $fixed -eq 0 ] && missing=$((missing + 1))
    fi
  done < <(ldd "$bin_path" 2>/dev/null)

  if [ $missing -eq 0 ]; then
    echo "  OK: $interp — semua dependencies tersedia"
  else
    echo "  WARNING: $interp masih ada $missing library yang tidak bisa di-resolve!"
  fi
done

# Copy direktori udev lengkap (rules, helpers, dll)
for udev_dir in /usr/lib/udev /lib/udev; do
  if [ -d "$udev_dir" ]; then
    cp -a "$udev_dir" $WDIR/usr/lib/ 2>/dev/null || true
    echo "Copied udev directory from $udev_dir"
  fi
done

# Install kernel modules
if [ -n "$KERNEL_VERSION" ]; then
  echo "Including modules for $KERNEL_VERSION..."

  for modpath in \
    /lib/modules/$KERNEL_VERSION/kernel/crypto \
    /lib/modules/$KERNEL_VERSION/kernel/fs \
    /lib/modules/$KERNEL_VERSION/kernel/lib \
    /lib/modules/$KERNEL_VERSION/kernel/drivers
  do
    [ -d "$modpath" ] && find "$modpath" -type f 2>/dev/null | cpio --make-directories -p --quiet $WDIR
  done

  # Copy module metadata ke usr/lib dan lib (beberapa modprobe carinya beda)
  mkdir -p $WDIR/usr/lib/modules/$KERNEL_VERSION
  mkdir -p $WDIR/lib/modules/$KERNEL_VERSION
  for f in modules.builtin modules.order modules.builtin.modinfo; do
    if [ -f /lib/modules/$KERNEL_VERSION/$f ]; then
      cp /lib/modules/$KERNEL_VERSION/$f $WDIR/usr/lib/modules/$KERNEL_VERSION/ 2>/dev/null || true
      cp /lib/modules/$KERNEL_VERSION/$f $WDIR/lib/modules/$KERNEL_VERSION/     2>/dev/null || true
    fi
  done

  depmod -b $WDIR $KERNEL_VERSION 2>/dev/null || true
fi

# Create initramfs
( cd $WDIR ; find . | cpio -o -H newc --quiet | gzip -9 ) > $INITRAMFS_FILE

SIZE=$(du -sh $INITRAMFS_FILE | cut -f1)
echo "done. (size: $SIZE)"

# Verifikasi binary penting
echo ""
echo "=== Verifying critical binaries ==="
for f in \
  init \
  usr/bin/sh \
  usr/bin/bash \
  usr/bin/mount \
  usr/bin/lsblk \
  usr/bin/losetup \
  usr/sbin/switch_root \
  usr/sbin/modprobe \
  usr/bin/udevadm; do
  if [ -f "$WDIR/$f" ] || [ -L "$WDIR/$f" ]; then
    echo "  OK: /$f"
  else
    echo "  MISSING: /$f  <-- WARNING!"
  fi
done

echo ""
echo "=== Verifying dynamic linker (fix untuk error -8) ==="
for f in \
  usr/lib/ld-linux-x86-64.so.2 \
  usr/lib/libc.so.6 \
  lib64; do
  if [ -f "$WDIR/$f" ] || [ -L "$WDIR/$f" ]; then
    target=""
    [ -L "$WDIR/$f" ] && target=" -> $(readlink $WDIR/$f)"
    echo "  OK: /$f$target"
  else
    echo "  MISSING: /$f  <-- CRITICAL! Binary tidak akan bisa jalan"
  fi
done

echo ""
echo "=== Verifying user setup files in initramfs ==="
for f in etc/passwd etc/shadow etc/group etc/sudoers; do
  if [ -f "$WDIR/$f" ]; then
    echo "  OK: /$f"
  else
    echo "  NOT PRESENT: /$f (normal, will be created by init)"
  fi
done

echo ""
echo "=== Loop device nodes ==="
for i in 0 1 2 3; do
  if [ -e "$WDIR/dev/loop$i" ]; then
    echo "  OK: /dev/loop$i"
  else
    echo "  MISSING: /dev/loop$i  <-- WARNING!"
  fi
done

# Verifikasi init executable
if [ -f "$WDIR/init" ]; then
  PERM=$(stat -c "%a" "$WDIR/init" 2>/dev/null)
  echo ""
  echo "=== Init permissions: $PERM (must be 755) ==="
fi

echo ""
echo "=== Initramfs size: $SIZE ==="

# Cleanup
rm -rf $WDIR $unsorted
